<Project Sdk="Microsoft.NET.Sdk">
    <PropertyGroup>
        <TargetFrameworks>net8.0;net9.0;net10.0;</TargetFrameworks>
        <LangVersion>latestMajor</LangVersion>
        <Version>5.6.1</Version>
        <Title>Downloader</Title>
        <Authors>Behzad Khosravifar</Authors>
        <Company>bezzad</Company>
        <Description>Fast and reliable multipart downloader with asynchronous progress events for .NET</Description>
        <PackageProjectUrl>https://github.com/bezzad/Downloader</PackageProjectUrl>
        <RepositoryUrl>https://github.com/bezzad/Downloader</RepositoryUrl>
        <PackageTags>download-manager, downloader, download, idm, internet, streaming, download-file, stream-downloader, multipart-download</PackageTags>
        <PackageReleaseNotes>
            Stability and quality follow-up to 5.6.0:
            * Made cancellation handling more robust: any exception thrown while the token is cancelled (including network/SSL errors) is now consistently reported as Stopped rather than Failed (follow-up to #225).
            * Fixed Download equality/GetHashCode: identity is now based on the immutable URL/folder/filename instead of the changing downloaded size, so the hash code is stable (safe as a dictionary/set key) and no longer throws for package-based downloads with a null URL.
            * CancelAsync now runs all cancellation callbacks even if one throws (Cancel(false)).
            * Removed a Debugger.Break() that could halt consuming applications under a debugger; replaced with a warning log.
            * Documentation: clarified that failures/cancellations are reported via the DownloadFileCompleted event (e.Error / e.Cancelled), not thrown by the awaited call, plus corrected several README code samples and added a recommended fast-and-reliable configuration.
        </PackageReleaseNotes>
        <SignAssembly>true</SignAssembly>
        <AssemblyOriginatorKeyFile>Downloader.snk</AssemblyOriginatorKeyFile>
        <Copyright>Copyright (C) 2019-2026 Behzad Khosravifar</Copyright>
        <PackageIcon>downloader.png</PackageIcon>
        <RepositoryType>git</RepositoryType>
        <PackageReadmeFile>README.md</PackageReadmeFile>
        <DebugType>embedded</DebugType>
        <ImplicitUsings>enable</ImplicitUsings>

        <!-- Optional: Publish the repository URL in the built .nupkg (in the NuSpec <Repository> element) -->
        <PublishRepositoryUrl>true</PublishRepositoryUrl>

        <!-- Optional: Build symbol package (.snupkg) to distribute the PDB containing Source Link -->
        <IncludeSymbols>true</IncludeSymbols>
        <PackageLicenseExpression>MIT</PackageLicenseExpression>
        <PackageRequireLicenseAcceptance>true</PackageRequireLicenseAcceptance>
    </PropertyGroup>

    <!-- Enable AOT Native Package -->
    <PropertyGroup>
        <PublishTrimmed>true</PublishTrimmed>
        <TrimMode>full</TrimMode>
        <PublishAot>true</PublishAot>
        <IsAotCompatible>true</IsAotCompatible>
        <EmitCompilerGeneratedFiles>true</EmitCompilerGeneratedFiles>
        <OptimizationPreference>Speed</OptimizationPreference>
        <StackTraceLineNumbers>true</StackTraceLineNumbers>
    </PropertyGroup>

    <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Debug|AnyCPU'">
        <DebugType>full</DebugType>
        <DebugSymbols>true</DebugSymbols>
    </PropertyGroup>

    <ItemGroup>
        <None Remove="downloader.png" />
        <None Include="..\..\LICENSE">
            <Pack>True</Pack>
            <PackagePath>\</PackagePath>
        </None>
        <None Include="..\..\README.md">
            <Pack>True</Pack>
            <PackagePath>\</PackagePath>
        </None>
        <None Include="downloader.png">
            <Pack>True</Pack>
            <PackagePath>\</PackagePath>
        </None>
    </ItemGroup>

    <ItemGroup>
        <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" Version="10.0.8" />
        <PackageReference Include="Microsoft.SourceLink.GitHub" Version="10.0.300" PrivateAssets="all" />
    </ItemGroup>

    <ItemGroup>
        <Resource Include="downloader.png" />
    </ItemGroup>
</Project>
